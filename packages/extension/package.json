{
  "name": "@degenlab/stacks-wallet-kit-extension",
  "version": "1.2.0",
  "repository": {
    "url": "git+https://github.com/degen-lab/stacks-wallet-kit",
    "type": "git"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "author": "DegenLab",
  "dependencies": {
    "@degenlab/stacks-wallet-kit-core": "workspace:*",
    "local-storage": "^2.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@scure/bip39": "^2.0.1",
    "@types/chrome": "^0.0.268",
    "@types/jest": "^29.5.14",
    "babel-jest": "^30.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "lint": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,json,md}'",
    "build": "tsc -b",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,json,md}'",
    "test": "jest"
  },
  "publishConfig": {
    "access": "public",
